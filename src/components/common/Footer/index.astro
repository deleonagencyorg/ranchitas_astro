---
// src/components/common/Footer/index.astro
import { t, type Locale } from '../../../i18n/i18n';
import { logos } from '../../../config/assets';
import './styles.css';
import Skeleton from './Skeleton.astro';
import LazyImage from '../LazyImage.astro';

export interface Props {
  currentLang: Locale;
  loading?: boolean;
}

const { currentLang, loading = false } = Astro.props;

// Obtener textos del footer desde los archivos de traducción
const mainText = t('footer.main_text', { namespace: 'common', locale: currentLang });
const description = t('footer.description', { namespace: 'common', locale: currentLang });
const followUs = t('footer.follow_us', { namespace: 'common', locale: currentLang });
const contactUs = t('footer.contact_us', { namespace: 'common', locale: currentLang });
const choose = t('footer.choose', { namespace: 'common', locale: currentLang });
const instagramText = t('footer.instagram_text', { namespace: 'common', locale: currentLang });
const facebookText = t('footer.facebook_text', { namespace: 'common', locale: currentLang });
const email = t('footer.email', { namespace: 'common', locale: currentLang });
const copyrightText = t('footer.copyright', { namespace: 'common', locale: currentLang });
const ranchitas = t('footer.ranchitas', { namespace: 'common', locale: currentLang });
const help = t('footer.help', { namespace: 'common', locale: currentLang });
const tiktokText = t('footer.tiktok_text', { namespace: 'common', locale: currentLang });
const socialMedia = t('social_media', { namespace: 'common', locale: currentLang }) as any;
const menuItems = t('menu_items', { namespace: 'common', locale: currentLang }) as any[];
const mainText2 = t('footer.main_text2', { namespace: 'common', locale: currentLang });
const emailPlaceholder = t('footer.email_placeholder', { namespace: 'common', locale: currentLang });
const subscribeButton = t('footer.subscribe_button', { namespace: 'common', locale: currentLang });
const contact = t('footer.contact', { namespace: 'common', locale: currentLang });

function getMenuHref(id: string) {
  return (menuItems || []).find((i: any) => i?.id === id)?.href;
}

const footerMenuItems = (menuItems || []).filter((i: any) => i && i.id !== 'brand' && i.id !== 'contact');
---

{loading ? (
  <Skeleton />
) : (
  <footer class="bg-[#D61F2C] text-white relative overflow-hidden z-10">
    <div class="w-full px-6 sm:px-10 lg:px-16 py-12 sm:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-12 lg:gap-24">
        
        <!-- Columna Izquierda: Título, Descripción y Newsletter -->
        <div class="flex flex-col items-center  md:text-left gap-4">
          <div class="flex flex-col gap-4 mb-12">
            <!-- logo -->
            <div class="">
              <img 
                src="https://snack.yummiespromociones.com/SnacksyummiesAssets/logobanner.png" 
                alt="Ranchitas" 
                class="w-32 sm:w-40"
              />
            </div>
            <!-- Footer Policy -->
            <div class="flex flex-col gap-2 mt-4 text-sm sm:text-base opacity-80">
              <a 
                href={`/${currentLang}/${currentLang === 'es' ? 'politica-de-privacidad' : 'privacy-policy'}`}
                class="hover:underline "
              >
                {currentLang === 'es' ? 'Política de Privacidad' : 'Privacy Policy'}
              </a>
              <span>
                {currentLang === 'es' ? 'Ranchitas 2026. Todos los Derechos Reservados' : 'Ranchitas 2026. All Rights Reserved'}
              </span>
            </div>
          </div>

          <h3 class="text-4xl sm:text-6xl font-bold mb-4 sm:mb-6 ">
            {mainText}<br />{mainText2}
          </h3>
          
          <!-- Formulario de Newsletter -->
          <div class="flex justify-center sm:justify-start">
            <a 
              href="https://www.snacksyummies.com/es/yummiesone" 
              target="_blank" 
              rel="noopener noreferrer"
              class="bg-[#F99F33] hover:bg-[#F99F33]/90 text-white font-title font-bold px-6 sm:px-12 py-3 sm:py-4 rounded-full transition-all duration-200 text-sm sm:text-lg whitespace-nowrap inline-block"
            >
              {currentLang === 'es' ? 'Regístrate en Yummies One' : 'Join Yummies One'}
            </a>
          </div>
        </div>

        <!-- Columna Derecha: Links de Navegación -->
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4 sm:gap-8 lg:gap-12 w-full">
          <!-- Ranchitas -->
          <div class="text-start">
            <h3 class="font-title text-lg sm:text-2xl font-bold mb-3 sm:mb-4 uppercase">
              {ranchitas}
            </h3>
            <div class="flex flex-col space-y-2 sm:space-y-3">
              {footerMenuItems.map((item: any) => (
                <a href={item.href} class="font-sans text-sm sm:text-xl hover:text-accent transition-colors duration-200">
                  {item.text}
                </a>
              ))}
            </div>
          </div>

          <!-- Redes Sociales -->
          <div class="text-start">
            <h3 class="font-title text-lg sm:text-2xl font-bold mb-3 sm:mb-4 uppercase">
              {followUs}
            </h3>
            <div class="flex flex-col space-y-2 sm:space-y-3">
              <a href={socialMedia?.facebook?.url || '#'} target="_blank" rel="noopener noreferrer" class="font-sans text-sm sm:text-xl hover:text-accent transition-colors duration-200">
                {facebookText}
              </a>
              <a href={socialMedia?.instagram?.url || '#'} target="_blank" rel="noopener noreferrer" class="font-sans text-sm sm:text-xl hover:text-accent transition-colors duration-200">
                {instagramText}
              </a>
              <a href={socialMedia?.tiktok?.url || '#'} target="_blank" rel="noopener noreferrer" class="font-sans text-sm sm:text-xl hover:text-accent transition-colors duration-200">
                {tiktokText}
              </a>
            </div>
          </div>

             <!-- Ayuda -->
          <div class="text-start">
            <h3 class="font-title text-lg sm:text-2xl font-bold mb-3 sm:mb-4 uppercase">
              {help}
            </h3>
            <div class="flex flex-col space-y-2 sm:space-y-3">
              <a href={getMenuHref('contact') || `/${currentLang}/${currentLang === 'es' ? 'contacto' : 'contact'}`} class="font-sans text-sm sm:text-xl hover:text-accent transition-colors duration-200">
                {contactUs}
              </a>
            </div>
          </div>
          

          <!-- Contacto -->
          <div class="col-span-2 md:col-span-3 w-full flex flex-col gap-4 md:items-start items-center">
            <div class="font-title text-lg sm:text-2xl font-bold uppercase">
              {currentLang === 'es' ? 'Contacto' : 'Contact'}
            </div>
            <ul class="grid grid-cols-2 font-sans gap-4 md:gap-2 text-sm md:text-lg justify-items-center md:grid-cols-2 justify-items-center md:justify-items-start [&>li]:whitespace-nowrap">
              <li class="flex items-center gap-2">
                <img src="https://snack.yummiespromociones.com/SnacksyummiesAssets/gt.webp" alt="Guatemala" class="w-4 h-4 md:w-5 md:h-4 object-contain">
                <a href="tel:+50225027050" class="hover:underline hover:text-blue">(+502) 2502-7050</a>
              </li>
              <li class="flex items-center gap-2">
                <img src="https://snack.yummiespromociones.com/SnacksyummiesAssets/sv.webp" alt="El Salvador" class="w-4 h-4 md:w-5 md:h-4 object-contain">
                <a href="tel:+50325108300" class="hover:underline hover:text-blue">(+503) 2510-8300</a>
              </li>
              <li class="flex items-center gap-2">
                <img src="https://snack.yummiespromociones.com/SnacksyummiesAssets/hn.webp" alt="Honduras" class="w-4 h-4 md:w-5 md:h-4 object-contain">
                <a href="tel:+50422753370" class="hover:underline hover:text-blue">(+504) 2275-3370</a>
              </li>
              <li class="flex items-center gap-2">
                <img src="https://snack.yummiespromociones.com/SnacksyummiesAssets/ni.webp" alt="Nicaragua" class="w-4 h-4 md:w-5 md:h-4 object-contain">
                <a href="tel:+50522557480" class="hover:underline hover:text-blue">(+505) 2255-7480</a>
              </li>
              <li class="flex items-center gap-2">
                <img src="https://snack.yummiespromociones.com/SnacksyummiesAssets/cr.webp" alt="Costa Rica" class="w-4 h-4 md:w-5 md:h-4 object-contain"  >
                <a href="tel:+50622710665" class="hover:underline hover:text-blue">(+506) 2271-0665</a>
              </li>
              <li class="flex items-center gap-2">
                <img src="https://snack.yummiespromociones.com/SnacksyummiesAssets/do.webp" alt="República Dominicana" class="w-4 h-4 md:w-5 md:h-4 object-contain"  >
                <a href="tel:+18092731042" class="hover:underline hover:text-blue">(+1) 809-273-1042</a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </footer>
)}