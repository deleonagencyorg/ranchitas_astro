---
import { t, setLocale, type Locale } from '../../../i18n/i18n';
import MainLayout from '../../../layouts/MainLayout.astro';
import PromotionDetail from '../../../views/Promotions/Detail/index.astro';

export function getStaticPaths() {
  const locales = ['es'];
  const paths = [];

  for (const locale of locales) {
    const promotions = t('items', { namespace: 'promotions', locale: locale as Locale }) || [];
    console.log(`Encontradas ${promotions.length} promociones para idioma ${locale}`);
    
    for (const promotion of promotions) {
      paths.push({
        params: { lang: locale, slug: promotion.slug },
        props: { promotion, currentLang: locale as Locale }
      });
    }
  }

  console.log(`Generadas ${paths.length} rutas de promociones en español`);
  return paths;
}

const { promotion, currentLang } = Astro.props;
const { lang, slug } = Astro.params;

setLocale(currentLang);

console.log(`Renderizando promoción: ${slug} en idioma: ${lang}`);
---

<MainLayout title={promotion.title}>
  <PromotionDetail currentLang={currentLang} promotionSlug={slug} />
</MainLayout>
