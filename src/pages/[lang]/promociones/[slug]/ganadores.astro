---
import MainLayout from '../../../../layouts/MainLayout.astro';
import WinnersView from '../../../../views/Promotions/Winners/index.astro';
import { setLocale } from '../../../../i18n/i18n';

export async function getStaticPaths() {
  const promotionsES = await import('../../../../locales/es/promotions.json');
  
  const paths = promotionsES.items
    .filter((promo: any) => promo.winners && Object.keys(promo.winners).length > 0)
    .map((promo: any) => ({
      params: { 
        lang: 'es',
        slug: promo.slug
      },
      props: { 
        promotionSlug: promo.slug
      }
    }));

  return paths;
}

const { lang, slug } = Astro.params;
const { promotionSlug } = Astro.props;

setLocale(lang as 'es' | 'en');
---

<MainLayout 
  title={`Ganadores - ${promotionSlug}`}
  description="Conoce a los ganadores de nuestra promoción"
>
  <WinnersView currentLang={lang as 'es' | 'en'} promotionSlug={promotionSlug} />
</MainLayout>
