---
import { t } from '../../../i18n/i18n';
import type { Locale } from '../../../i18n/i18n';

interface Props {
  currentLang: Locale;
  promotionSlug: string;
}

const { currentLang, promotionSlug } = Astro.props;

const promotions = t('items', { namespace: 'promotions', locale: currentLang }) || [];
const promotion = promotions.find((p: any) => p.slug === promotionSlug);

if (!promotion) {
  throw new Error(`Promotion with slug ${promotionSlug} not found`);
}

const backText = currentLang === 'es' ? 'Volver a la promoción' : 'Back to promotion';
const backUrl = `/${currentLang}/${currentLang === 'es' ? 'promociones' : 'promotions'}/${promotionSlug}`;
const winnersTitle = currentLang === 'es' ? 'Ganadores' : 'Winners';
const winnersSubtitle = currentLang === 'es' ? 'Descubre quiénes fueron los últimos' : 'Discover who were the last';
const winnersHighlight = currentLang === 'es' ? 'ganadores' : 'winners';

const countries = [
  { code: 'GT', name: currentLang === 'es' ? 'Guatemala' : 'Guatemala', count: promotion.winners?.GT?.length || 0 },
  { code: 'SV', name: currentLang === 'es' ? 'El Salvador' : 'El Salvador', count: promotion.winners?.SV?.length || 0 },
  { code: 'CR', name: 'Costa Rica', count: promotion.winners?.CR?.length || 0 },
  { code: 'NI', name: 'Nicaragua', count: promotion.winners?.NI?.length || 0 },
  { code: 'HN', name: 'Honduras', count: promotion.winners?.HN?.length || 0 }
];
---

<div class="bg-primaryCream min-h-screen">
  <!-- Header Section -->
  <section class="w-full px-4 sm:px-6 lg:px-8 py-8">
    <div class="max-w-7xl mx-auto">
      <div class="mb-6">
        <a 
          href={backUrl}
          class="inline-flex items-center text-gray-600 hover:text-gray-900 transition-colors font-medium"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          {backText}
        </a>
      </div>

      <div class="mb-8">
        <p class="text-orange-500 font-bold text-sm mb-2">{winnersTitle}</p>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-2">
          {winnersSubtitle} <span class="text-orange-500">{winnersHighlight}</span>
        </h1>
        <p class="text-lg text-gray-600 mt-4">{promotion.title}</p>
      </div>
    </div>
  </section>

  <!-- Winners Section -->
  {promotion.winners && Object.keys(promotion.winners).length > 0 && (
    <section class="w-full px-4 sm:px-6 lg:px-8 py-8 pb-16">
      <div class="max-w-7xl mx-auto">
        <!-- Country Tabs -->
        <div class="flex flex-wrap gap-2 mb-8 border-b-2 border-gray-200 pb-4">
          {countries.filter(c => c.count > 0).map((country, index) => (
            <button 
              type="button"
              class={`country-tab px-6 py-2 font-bold transition-colors ${index === 0 ? 'text-orange-500 border-b-4 border-orange-500' : 'text-gray-600 hover:text-orange-500'}`}
              data-country={country.code}
            >
              {country.name} ({country.count})
            </button>
          ))}
        </div>

        <!-- Winners Grid -->
        <div id="winners-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-6">
          {/* Default winners for first country with winners */}
          {(() => {
            const firstCountryWithWinners = countries.find(c => c.count > 0);
            if (!firstCountryWithWinners) return null;
            
            const winners = promotion.winners[firstCountryWithWinners.code] || [];
            return winners.map((winner: any) => (
              <div class="bg-white rounded-3xl overflow-hidden shadow-lg winner-card" data-country={firstCountryWithWinners.code}>
                <div class="h-64 bg-gray-200 flex items-center justify-center border-4 border-blue-400">
                  <img 
                    src={winner.image || '/images/placeholder.jpg'}
                    alt={winner.name}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
                <div class="bg-[#F97316] p-6">
                  <h3 class="text-xl font-bold text-white mb-2">
                    {winner.name}
                  </h3>
                  <p class="text-white/90 text-sm">
                    {winner.description}
                  </p>
                </div>
              </div>
            ));
          })()}
        </div>

        <!-- Hidden winners data for other countries -->
        <div id="winners-data" class="hidden">
          {Object.entries(promotion.winners || {}).map(([countryCode, winners]: [string, any]) => (
            <div data-country={countryCode}>
              {winners.map((winner: any) => (
                <div data-winner={JSON.stringify(winner)}></div>
              ))}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {(!promotion.winners || Object.keys(promotion.winners).length === 0) && (
    <section class="w-full px-4 sm:px-6 lg:px-8 py-16">
      <div class="max-w-7xl mx-auto text-center">
        <p class="text-xl text-gray-500">
          {currentLang === 'es' ? 'Aún no hay ganadores para esta promoción' : 'No winners yet for this promotion'}
        </p>
      </div>
    </section>
  )}
</div>

<script>
function configurarFiltros() {
  document.querySelectorAll('img').forEach(img => {
    if (!img.hasAttribute('data-fixed')) {
      img.setAttribute('data-fixed', 'true');
      img.onerror = function() {
        this.src = '/images/placeholder.jpg';
      };
    }
  });
  
  const botones = document.querySelectorAll('.country-tab');
  
  if (botones.length === 0) {
    return false;
  }
  
  botones.forEach(boton => {
    if (boton.hasAttribute('data-configured')) {
      return;
    }
    
    boton.setAttribute('data-configured', 'true');
    
    boton.addEventListener('click', function() {
      const pais = this.getAttribute('data-country');
      
      if (!pais) {
        return;
      }
      
      botones.forEach(b => {
        b.classList.remove('text-orange-500', 'border-b-4', 'border-orange-500');
        b.classList.add('text-gray-600');
      });
      this.classList.remove('text-gray-600');
      this.classList.add('text-orange-500', 'border-b-4', 'border-orange-500');
      
      filtrarGanadores(pais);
    });
  });
  
  return true;
}

function filtrarGanadores(codigoPais) {
  const contenedor = document.getElementById('winners-grid');
  const datosOcultos = document.getElementById('winners-data');
  
  if (!contenedor || !datosOcultos) {
    return;
  }
  
  const paisDiv = datosOcultos.querySelector(`[data-country="${codigoPais}"]`);
  
  if (!paisDiv) {
    contenedor.innerHTML = '<p class="text-center py-8">No hay ganadores para este país</p>';
    return;
  }
  
  let html = '';
  const elementosGanador = paisDiv.querySelectorAll('[data-winner]');
  
  elementosGanador.forEach(elemento => {
    const datos = elemento.getAttribute('data-winner');
    if (datos) {
      try {
        const ganador = JSON.parse(datos);
        html += `
          <div class="bg-white rounded-3xl overflow-hidden shadow-lg">
            <div class="h-64 bg-gray-200 border-4 border-blue-400">
              <img 
                src="${ganador.image || '/images/placeholder.jpg'}"
                alt="${ganador.name}"
                class="w-full h-full object-cover"
                onerror="this.src='/images/placeholder.jpg'"
              />
            </div>
            <div class="bg-[#F97316] p-6">
              <h3 class="text-xl font-bold text-white">${ganador.name}</h3>
              <p class="text-white/90 text-sm">${ganador.description}</p>
            </div>
          </div>
        `;
      } catch (error) {
        console.error('Error procesando ganador:', error);
      }
    }
  });
  
  contenedor.innerHTML = html || '<p class="text-center py-8">No hay ganadores para este país</p>';
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', configurarFiltros);
} else {
  configurarFiltros();
}

document.addEventListener('astro:page-load', function() {
  setTimeout(configurarFiltros, 50);
});

document.addEventListener('astro:after-swap', configurarFiltros);

setTimeout(configurarFiltros, 100);
setTimeout(configurarFiltros, 500);
</script>