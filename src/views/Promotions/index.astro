---
import { t } from '../../i18n/i18n';
import type { Locale } from '../../i18n/i18n';
import { getLocale } from '../../i18n/i18n';

const currentLang = getLocale();
const promotions = t('items', { namespace: 'promotions', locale: currentLang }) || [];
const pageData = t('page', { namespace: 'promotions', locale: currentLang }) || {};

const activePromotions = promotions.filter((p: any) => p.status === 'active');
const expiredPromotions = promotions.filter((p: any) => p.status === 'expired');
const featuredPromotion = activePromotions[0] || promotions[0];
const otherActivePromotions = activePromotions.slice(1);

const heroTitle = currentLang === 'es' 
  ? 'Gana premios increíbles participando hoy'
  : 'Win amazing prizes by participating today';
const heroSubtitle = currentLang === 'es'
  ? 'Tenemos una oportunidad especial esperándote. Registra tu código y forma parte de nuestra comunidad ganadora'
  : 'We have a special opportunity waiting for you. Register your code and become part of our winning community';
const heroButton = currentLang === 'es' ? 'Participar ahora' : 'Participate now';
const activeSectionTitle = currentLang === 'es' ? 'DESCUBRE LAS PROMOCIONES ACTIVAS' : 'DISCOVER ACTIVE PROMOTIONS';
const expiredSectionTitle = currentLang === 'es' ? 'CONOCE LAS PROMOCIONES FINALIZADAS' : 'CHECK OUT FINISHED PROMOTIONS';
const featuredLabel = currentLang === 'es' ? 'Destacado' : 'Featured';
const viewMoreButton = currentLang === 'es' ? 'Ver ganadores' : 'View winners';
---

<div class="bg-primaryCream min-h-screen">
  <!-- Hero Section -->
  {featuredPromotion && (
    <section class="w-full px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
      <div class="max-w-7xl mx-auto">
        <div class="bg-gradient-to-br from-gray-400 to-gray-500 rounded-3xl overflow-hidden relative min-h-[300px] sm:min-h-[400px] lg:min-h-[500px]"
             style={featuredPromotion.banner_desktop ? `background-image: url(${featuredPromotion.banner_desktop}); background-size: cover; background-position: center;` : ''}>
          <div class="absolute inset-0 bg-black/40"></div>
          <div class="relative z-10 flex flex-col items-center justify-center text-center px-6 py-12 sm:py-16 lg:py-20 h-full">
            <h1 class="text-3xl sm:text-4xl lg:text-6xl font-bold text-white mb-4 sm:mb-6 max-w-4xl leading-tight">
              {heroTitle}
            </h1>
            <p class="text-base sm:text-lg lg:text-xl text-white/90 mb-6 sm:mb-8 max-w-2xl">
              {heroSubtitle}
            </p>
            <a 
              href={featuredPromotion.cta_link || `/${currentLang}/${currentLang === 'es' ? 'promociones' : 'promotions'}/${featuredPromotion.slug}`}
              class="bg-[#D61F2C] hover:bg-[#B91C1C] text-white font-bold px-8 sm:px-12 py-3 sm:py-4 rounded-full transition-all duration-300 text-base sm:text-lg shadow-lg hover:shadow-xl transform hover:scale-105"
            >
              {heroButton}
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Active Promotions Section -->
  {activePromotions.length > 0 && (
    <section class="w-full px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold mb-6 sm:mb-8 lg:mb-12">
          {activeSectionTitle}
        </h2>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8">
          {activePromotions.map((promo: any, index: number) => (
            <div class="bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1">
              <div class="relative h-48 sm:h-56 lg:h-64 bg-gray-200">
                <img 
                  src={promo.image || '/images/placeholder.jpg'} 
                  alt={promo.title}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
                {index === 0 && (
                  <div class="absolute top-4 left-4 bg-white text-black px-4 py-2 rounded-full text-sm font-bold">
                    {featuredLabel}
                  </div>
                )}
              </div>
              
              <div class={`p-6 ${index === 0 ? 'bg-white' : promo.prizes?.length > 0 ? 'bg-[#7CB342]' : 'bg-[#7CB342]'}`}>
                {index === 0 ? (
                  <>
                    <div class="mb-3">
                      <span class="text-xs font-semibold text-gray-500 uppercase">{featuredLabel}</span>
                    </div>
                    <h3 class="text-xl font-bold mb-3 text-black">{promo.title}</h3>
                    <p class="text-gray-600 text-sm mb-4 line-clamp-2">
                      {promo.short_description}
                    </p>
                    <a 
                      href={`/${currentLang}/${currentLang === 'es' ? 'promociones' : 'promotions'}/${promo.slug}`}
                      class="inline-block bg-[#7CB342] hover:bg-[#689F38] text-white font-bold px-6 py-2 rounded-full transition-colors duration-300 text-sm"
                    >
                      {pageData.view_details || 'Ver más'}
                    </a>
                  </>
                ) : (
                  <>
                    <div class="flex items-start mb-4">
                      <svg class="w-8 h-8 text-white mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                      </svg>
                      <div>
                        <h3 class="text-lg font-bold text-white mb-2">{promo.title}</h3>
                        <p class="text-white/90 text-sm line-clamp-2">
                          {promo.short_description}
                        </p>
                      </div>
                    </div>
                    <a 
                      href={`/${currentLang}/${currentLang === 'es' ? 'promociones' : 'promotions'}/${promo.slug}`}
                      class="inline-block bg-white hover:bg-gray-100 text-[#7CB342] font-bold px-6 py-2 rounded-full transition-colors duration-300 text-sm"
                    >
                      {pageData.view_details || 'Ver más'}
                    </a>
                  </>
                )}
              </div>
            </div>
          ))}
          
          <!-- Info Cards Verdes -->
          <div class="bg-[#7CB342] rounded-3xl p-8 shadow-lg flex flex-col justify-center min-h-[280px]">
            <svg class="w-12 h-12 text-white mb-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
            </svg>
            <h3 class="text-xl font-bold text-white mb-3">
              {currentLang === 'es' ? 'Premios esperándote' : 'Prizes waiting for you'}
            </h3>
            <p class="text-white/90 text-sm">
              {currentLang === 'es' 
                ? 'Descubre qué puedes ganar siendo parte de esta iniciativa' 
                : 'Discover what you can win by being part of this initiative'}
            </p>
          </div>

          <div class="bg-[#7CB342] rounded-3xl p-8 shadow-lg flex flex-col justify-center min-h-[280px]">
            <svg class="w-12 h-12 text-white mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
            <h3 class="text-xl font-bold text-white mb-3">
              {currentLang === 'es' ? 'Participación rápida y fácil' : 'Quick and easy participation'}
            </h3>
            <p class="text-white/90 text-sm">
              {currentLang === 'es' 
                ? 'El proceso es directo sin complicaciones ni trámites largos' 
                : 'The process is straightforward without complications or long procedures'}
            </p>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Expired Promotions Section -->
  {expiredPromotions.length > 0 && (
    <section class="w-full px-4 sm:px-6 lg:px-8 py-8 lg:py-12 pb-16">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold mb-6 sm:mb-8 lg:mb-12">
          {expiredSectionTitle}
        </h2>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
          {expiredPromotions.map((promo: any) => (
            <div class="bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300">
              <div class="relative h-40 sm:h-48 bg-gray-200">
                <img 
                  src={promo.image || '/images/placeholder.jpg'} 
                  alt={promo.title}
                  class="w-full h-full object-cover opacity-75"
                  loading="lazy"
                />
              </div>
              
              <div class="bg-[#D61F2C] p-6">
                <div class="flex items-start mb-4">
                  <svg class="w-8 h-8 text-white mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                  </svg>
                  <div>
                    <h3 class="text-lg font-bold text-white mb-2">{promo.title}</h3>
                    <p class="text-white/90 text-sm line-clamp-2">
                      {promo.short_description}
                    </p>
                  </div>
                </div>
                <a 
                  href={`/${currentLang}/${currentLang === 'es' ? 'promociones' : 'promotions'}/${promo.slug}`}
                  class="inline-block bg-white hover:bg-gray-100 text-[#D61F2C] font-bold px-6 py-2 rounded-full transition-colors duration-300 text-sm"
                >
                  {viewMoreButton}
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {!Array.isArray(promotions) || promotions.length === 0 && (
    <div class="w-full px-4 py-20 text-center">
      <p class="text-xl text-gray-500">{pageData.no_promotions}</p>
    </div>
  )}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const images = document.querySelectorAll('img');
    images.forEach(img => {
      img.addEventListener('error', function() {
        this.src = '/images/placeholder.jpg';
      });
    });
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
