---
import { t } from '../../../i18n/i18n';
import type { Locale } from '../../../i18n/i18n';

interface Props {
  currentLang: Locale;
  promotionSlug: string;
}

const { currentLang, promotionSlug } = Astro.props;

const promotions = t('items', { namespace: 'promotions', locale: currentLang }) || [];
const promotion = promotions.find((p: any) => p.slug === promotionSlug);

if (!promotion) {
  throw new Error(`Promotion with slug ${promotionSlug} not found`);
}

const backText = currentLang === 'es' ? 'Volver a promociones' : 'Back to promotions';
const backUrl = `/${currentLang}/${currentLang === 'es' ? 'promociones' : 'promotions'}`;
const howToParticipateTitle = currentLang === 'es' ? '¿Cómo participar?' : 'How to participate?';
const followStepsText = currentLang === 'es' ? 'Sigue cada uno de estos pasos para' : 'Follow each of these steps to';
const participateHighlight = currentLang === 'es' ? 'poder participar' : 'be able to participate';
const prizesTitle = currentLang === 'es' ? 'DESCUBRE LOS PREMIOS QUE TENEMOS PARA TI' : 'DISCOVER THE PRIZES WE HAVE FOR YOU';
const winnersSubtitle = currentLang === 'es' ? 'Descubre quiénes fueron los últimos' : 'Discover who were the last';
const winnersHighlight = currentLang === 'es' ? 'ganadores' : 'winners';
---

<div class="bg-primaryCream min-h-screen">
  <!-- Hero Section -->
  <section class="w-full px-4 sm:px-6 lg:px-8 py-8">
    <div class="max-w-7xl mx-auto">
      <div class="mb-6">
        <a 
          href={backUrl}
          class="inline-flex items-center text-gray-600 hover:text-gray-900 transition-colors font-medium"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          {backText}
        </a>
      </div>

      <div class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-3xl overflow-hidden relative min-h-[250px] sm:min-h-[300px] lg:min-h-[400px] flex items-center"
           style={promotion.banner_desktop ? `background-image: url(${promotion.banner_desktop}); background-size: cover; background-position: center;` : ''}>
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="relative z-10 w-full px-6 sm:px-8 lg:px-12 py-8 lg:py-12">
          <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
            <div class="flex-1 text-white">
              <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 leading-tight">
                {promotion.title}
              </h1>
              <p class="text-base sm:text-lg text-white/90 max-w-2xl mb-6">
                {promotion.description}
              </p>
              {promotion.winners && Object.keys(promotion.winners).length > 0 && (
                <a 
                  href={`/${currentLang}/${currentLang === 'es' ? 'promociones' : 'promotions'}/${promotion.slug}/${currentLang === 'es' ? 'ganadores' : 'winners'}`}
                  class="inline-block bg-[#F97316] hover:bg-[#EA580C] text-white font-bold px-6 sm:px-8 py-3 rounded-full transition-all duration-300 text-sm sm:text-base shadow-lg"
                >
                  {currentLang === 'es' ? 'Ver ganadores' : 'View winners'}
                </a>
              )}
            </div>
            <div class="w-full lg:w-80 h-48 lg:h-64 bg-gray-600 rounded-2xl flex-shrink-0">
              <img 
                src={promotion.image || '/images/promotions/placeholder.jpg'}
                alt={promotion.title}
                class="w-full h-full object-cover rounded-2xl"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How to Participate Section -->
  {promotion.how_to_participate && promotion.how_to_participate.length > 0 && (
    <section class="w-full px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
      <div class="max-w-7xl mx-auto">
        <div class="mb-8">
          <p class="text-orange-500 font-bold text-sm mb-2">{howToParticipateTitle}</p>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-2">
            {followStepsText} <span class="text-orange-500">{participateHighlight}</span>
          </h2>
        </div>

        <ol class="space-y-4 mb-8">
          {promotion.how_to_participate.map((step: string, index: number) => (
            <li class="flex items-start">
              <span class="font-bold text-lg mr-3 flex-shrink-0">{index + 1}.</span>
              <p class="text-gray-700 text-base sm:text-lg">{step}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>
  )}

  <!-- CTA Banner -->
  <section class="w-full px-4 sm:px-6 lg:px-8 py-8">
    <div class="max-w-7xl mx-auto">
      <div class="bg-gradient-to-br from-gray-500 to-gray-600 rounded-3xl overflow-hidden relative min-h-[300px] flex items-center justify-center text-center px-6 py-12">
        <div class="absolute inset-0 bg-black/30"></div>
        <div class="relative z-10">
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
            {promotion.title}
          </h2>
          <p class="text-white/90 text-base sm:text-lg mb-6 max-w-2xl mx-auto">
            {promotion.short_description}
          </p>
          {promotion.cta_text && promotion.cta_link && (
            <a 
              href={promotion.cta_link}
              class="inline-block bg-[#D61F2C] hover:bg-[#B91C1C] text-white font-bold px-8 py-3 rounded-full transition-all duration-300 text-lg shadow-lg"
            >
              {promotion.cta_text}
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Prizes Section -->
  {promotion.prizes && promotion.prizes.length > 0 && (
    <section class="w-full px-4 sm:px-6 lg:px-8 py-8 lg:py-12">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold mb-8 lg:mb-12">
          {prizesTitle}
        </h2>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {promotion.prizes.map((prize: any) => (
            <div class="bg-white rounded-3xl overflow-hidden shadow-lg">
              <div class="h-48 bg-gray-200 flex items-center justify-center">
                <svg class="w-20 h-20 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm12 12H4l4-8 3 6 2-4 3 6z" clip-rule="evenodd"></path>
                </svg>
              </div>
              <div class="bg-[#7CB342] p-6">
                <h3 class="text-xl font-bold text-white mb-2">{prize.name}</h3>
                <p class="text-white/90 text-sm">
                  {prize.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- FAQs Section -->
  {promotion.faqs && promotion.faqs.length > 0 && (
    <section class="w-full px-4 sm:px-6 lg:px-8 py-8 lg:py-12 pb-16">
      <div class="max-w-7xl mx-auto bg-white rounded-3xl px-6 sm:px-8 lg:px-12 py-8 lg:py-12">
        <h2 class="text-xl sm:text-2xl font-bold mb-6 lg:mb-8 uppercase">
          {currentLang === 'es' ? 'PREGUNTAS FRECUENTES' : 'FREQUENTLY ASKED QUESTIONS'}
        </h2>
        
        <div class="divide-y divide-gray-200">
          {promotion.faqs.map((faq: any, index: number) => (
            <div class="faq-item">
              <button 
                type="button"
                class="faq-button w-full flex items-center justify-between py-5 text-left transition-colors"
                data-faq-index={index}
              >
                <span class="text-sm sm:text-base text-gray-900 pr-4 flex-1">
                  {faq.question}
                </span>
                <svg 
                  class="faq-icon w-5 h-5 text-gray-900 flex-shrink-0 transition-transform duration-300" 
                  fill="none" 
                  stroke="currentColor" 
                  viewBox="0 0 24 24"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path>
                </svg>
              </button>
              <div class="faq-content hidden pb-5">
                <p class="text-gray-700 text-sm sm:text-base leading-relaxed pr-8">
                  {faq.answer}
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const images = document.querySelectorAll('img');
    images.forEach(img => {
      img.addEventListener('error', function() {
        this.src = '/images/promotions/placeholder.jpg';
      });
    });

    // FAQ Accordion functionality
    const faqButtons = document.querySelectorAll('.faq-button');
    faqButtons.forEach(button => {
      button.addEventListener('click', () => {
        const content = button.nextElementSibling as HTMLElement;
        const icon = button.querySelector('.faq-icon') as HTMLElement;
        const isOpen = !content.classList.contains('hidden');

        if (isOpen) {
          content.classList.add('hidden');
          icon.style.transform = 'rotate(0deg)';
        } else {
          content.classList.remove('hidden');
          icon.style.transform = 'rotate(45deg)';
        }
      });
    });
  });
</script>
